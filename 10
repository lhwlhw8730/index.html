<!DOCTYPE html>
<html class="light" lang="ko">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface-container-lowest": "#ffffff",
                        "surface": "#faf8ff",
                        "surface-container-low": "#f2f3fe",
                        "surface-container": "#ededf8",
                        "error": "#ba1a1a",
                        "surface-dim": "#d9d9e4",
                        "surface-variant": "#e1e2ec",
                        "primary-fixed": "#dae2ff",
                        "primary": "#0040a1",
                        "inverse-surface": "#2e3038",
                        "on-surface": "#191b23",
                        "error-container": "#ffdad6",
                        "on-primary": "#ffffff",
                        "on-tertiary": "#ffffff",
                        "inverse-primary": "#b2c5ff",
                        "on-tertiary-fixed-variant": "#00531e",
                        "on-tertiary-container": "#54f67a",
                        "secondary": "#705d00",
                        "primary-container": "#0056d2",
                        "outline": "#737785",
                        "outline-variant": "#c3c6d6",
                        "tertiary-container": "#006e2a",
                        "tertiary-fixed": "#69ff87",
                        "on-primary-fixed-variant": "#0040a1",
                        "secondary-container": "#fdd400",
                        "on-surface-variant": "#424654",
                        "on-secondary-container": "#6f5c00",
                        "secondary-fixed-dim": "#e9c400",
                        "surface-container-highest": "#e1e2ec",
                        "surface-bright": "#faf8ff",
                        "tertiary": "#00531e",
                        "inverse-on-surface": "#f0f0fb",
                        "primary-fixed-dim": "#b2c5ff",
                        "on-secondary-fixed-variant": "#544600",
                        "on-error-container": "#93000a",
                        "on-error": "#ffffff",
                        "on-secondary-fixed": "#221b00",
                        "tertiary-fixed-dim": "#3ce36a",
                        "on-secondary": "#ffffff",
                        "surface-container-high": "#e7e7f2",
                        "background": "#faf8ff",
                        "on-background": "#191b23",
                        "surface-tint": "#0056d2",
                        "on-primary-fixed": "#001847",
                        "secondary-fixed": "#ffe170",
                        "on-primary-container": "#ccd8ff",
                        "on-tertiary-fixed": "#002108"
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Be Vietnam Pro"],
                        "label": ["Be Vietnam Pro"]
                    },
                    borderRadius: { "DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        body {
            /* 모바일 앱 느낌을 위해 터치 시 하이라이트 제거 및 스크롤 방지 */
            -webkit-tap-highlight-color: transparent;
            overflow: hidden;
            height: 100dvh;
        }

        /* 맵 이미지가 모바일에서 밀리지 않도록 고정 */
        .map-container {
            height: 100dvh;
            width: 100%;
            position: absolute;
            top: 0;
            left: 0;
        }
    </style>
</head>
<body class="bg-surface font-body text-on-surface antialiased">
    <!-- 전체 컨테이너 (모바일 래퍼) -->
    <div class="relative h-[100dvh] w-full max-w-md mx-auto bg-white overflow-hidden shadow-2xl">
        
        <!-- TopAppBar -->
        <header class="absolute top-0 w-full z-50 bg-white/80 backdrop-blur-md">
            <div class="flex justify-between items-center px-5 py-3">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-primary-fixed flex items-center justify-center overflow-hidden border border-primary/10">
                        <img alt="Student Profile" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB_UG9bhNrX8Vn-h6wGtAxmyZX3YIHkRk6f6x07hn2HN0bnHerzY5R9ckpPC228PI4CMhcw7qhHmvYYQEAgSD4YqW23xx5nmII8k4W-9kmK2uf_isrGOOVyUYvX-we61TuM6vj0xaomeJXl6amhTXcT7oRbJZTCN-raBNEtXDPhyCINooWKr2tV7PVNijv1f5kwcAAWv6slnqhCNNsce87NNoAo9qRnXb2z3EzJNS2k6dmIYr8LftBJQ9YGsdTnsQcO8WbbG_XVwHs" />
                    </div>
                    <h1 class="text-lg font-extrabold text-blue-700 font-headline tracking-tight">Academic Concierge</h1>
                </div>
                <button class="text-blue-700 hover:bg-slate-100 p-2 rounded-full active:scale-90 transition-transform">
                    <span class="material-symbols-outlined text-2xl">notifications</span>
                </button>
            </div>
        </header>

        <!-- Main Map Area -->
        <main class="relative h-full w-full">
            <!-- Map Background Layer -->
            <div class="map-container z-0">
                <div class="w-full h-full bg-surface-container-low relative">
                    <img alt="Campus Map" class="w-full h-full object-cover opacity-60 scale-125" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDjpzgViCTnf4aKoy0dcVzIisSWXAjF60wnrhALLd76_1h5PVC7gCQaYtvEogm211BRlJ1V5HedqzoKKInSR6w9g-ZaUg7XBlOJqV0IDnRaxhQa5LMeijKqdA6XeM5YoLbGRXwOF3zjwYq7sMJPr7I5csczTJ73ia3d08nvTPUAh7ynzqEHatctR-M7TibUq8b2bNfTDxKoY9Viu2cGgyeNNcoNRDiW98ioKZBf4-YVg27-1NHqC2NW96vdUW6qd7fxoiYLqdStUj0" />
                    
                    <!-- Markers -->
                    <div class="absolute top-1/4 left-1/4">
                        <div class="relative flex flex-col items-center animate-bounce">
                            <div class="bg-primary p-2 rounded-full shadow-lg">
                                <div class="w-2.5 h-2.5 bg-secondary-container rounded-full"></div>
                            </div>
                            <div class="mt-1 bg-white/90 px-2 py-0.5 rounded-full shadow-sm border border-outline-variant/30 backdrop-blur-sm">
                                <span class="text-[10px] font-bold text-primary">보조배터리</span>
                            </div>
                        </div>
                    </div>
                    <div class="absolute top-1/2 right-1/4">
                        <div class="relative flex flex-col items-center">
                            <div class="bg-primary p-2 rounded-full shadow-lg">
                                <div class="w-2.5 h-2.5 bg-secondary-container rounded-full"></div>
                            </div>
                            <div class="mt-1 bg-white/90 px-2 py-0.5 rounded-full shadow-sm border border-outline-variant/30 backdrop-blur-sm">
                                <span class="text-[10px] font-bold text-primary">경제학 서적</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- UI Overlay -->
            <div class="absolute inset-0 z-10 pointer-events-none flex flex-col">
                <!-- Search & Filters -->
                <div class="px-5 pt-20 pointer-events-auto">
                    <div class="bg-white/90 backdrop-blur-xl rounded-2xl shadow-lg border border-slate-100 p-1.5">
                        <div class="flex items-center gap-2 px-3 py-1.5">
                            <span class="material-symbols-outlined text-outline text-xl">search</span>
                            <input class="bg-transparent border-none focus:ring-0 w-full text-sm font-medium placeholder:text-outline-variant" placeholder="보조배터리, 전공서적 등 검색" type="text" />
                        </div>
                    </div>
                    <div class="flex gap-2 mt-3 overflow-x-auto no-scrollbar pb-1">
                        <button class="flex-shrink-0 bg-primary text-on-primary px-4 py-1.5 rounded-full text-xs font-bold flex items-center gap-1 shadow-md active:scale-95 transition-transform">
                            <span class="material-symbols-outlined text-[16px]">tune</span> 필터
                        </button>
                        <button class="flex-shrink-0 bg-white/90 text-on-surface-variant px-4 py-1.5 rounded-full text-xs font-semibold border border-outline-variant/20 shadow-sm">도서류</button>
                        <button class="flex-shrink-0 bg-white/90 text-on-surface-variant px-4 py-1.5 rounded-full text-xs font-semibold border border-outline-variant/20 shadow-sm">전자기기</button>
                        <button class="flex-shrink-0 bg-white/90 text-on-surface-variant px-4 py-1.5 rounded-full text-xs font-semibold border border-outline-variant/20 shadow-sm">생활용품</button>
                    </div>
                </div>

                <!-- Spacer -->
                <div class="flex-grow"></div>

                <!-- Item Cards Carousel -->
                <div class="pointer-events-auto overflow-x-auto no-scrollbar flex gap-4 px-5 pb-32 pt-4 snap-x snap-mandatory">
                    <!-- Card 1 -->
                    <div class="min-w-[260px] snap-center bg-white rounded-2xl p-2.5 shadow-xl border border-slate-50">
                        <div class="relative aspect-[16/10] rounded-xl overflow-hidden mb-2.5">
                            <img alt="Power bank" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCvObs9-Ws24vQ0Ua6jLGH6qjBCv9TI-xK5cnK9CYYjlcGPVMot6lLVNB0vhyzD5XebZCQ0HleVwaswBNWMy1nSV3KbwwB9fjYe61f7c4u2f2v97woJBLhpGjF7q68GsYoqnUQTbgWC0tHsFr8yF8jNGeDAcu0dQios5kpVxfKDP-eGrqtUZoXl45wFIuWI7WAu86NzP7CYHByzvWLsFE-7CRDd2dgOa7h21_Bf5heUE-AnBwxs6qvPbSm2t4mXQCM1byZ0DMa6t5g" />
                            <div class="absolute top-2 right-2">
                                <span class="bg-secondary-container/90 backdrop-blur-sm text-on-secondary-container px-2 py-0.5 rounded-md text-[9px] font-extrabold uppercase">AVAILABLE</span>
                            </div>
                        </div>
                        <div class="px-1">
                            <h3 class="font-headline font-bold text-sm text-on-surface mb-2 line-clamp-1">C타입 보조배터리 20000mAh</h3>
                            <div class="flex justify-between items-end">
                                <div>
                                    <span class="text-primary font-bold text-base">2,000원</span>
                                    <span class="text-outline text-[10px]">/일</span>
                                </div>
                                <div class="flex flex-col items-end">
                                    <span class="text-[9px] font-bold text-primary mb-0.5">매너 38.5°C</span>
                                    <div class="w-14 h-1 bg-slate-100 rounded-full overflow-hidden">
                                        <div class="h-full bg-primary w-[70%]"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 2 -->
                    <div class="min-w-[260px] snap-center bg-white rounded-2xl p-2.5 shadow-xl border border-slate-50">
                        <div class="relative aspect-[16/10] rounded-xl overflow-hidden mb-2.5">
                            <img alt="Economics Book" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDMMstEg480SrZoEB_6ThoSE9iDzLu5HTpbucINBjlJsEl3EKCqMc8Fjlf8tziL-BorGzeqJ1azCLNcrib5lkiLtyuC6S8HyNJX7iXmUfECwxCyn-F16nQ4QVFhiir6WYcpA51SXoIIpP3_uLrVx9IGmtPqXDNYF6uoAUfaAzxwnmnNLVS4ilWyskyo1nZYCwZ7jYraihS49pXKIRBcMCeNaRqGUb0TgpWiU4g8M_nNYna5QYkLl6umN4XboONIlBFX191BCR-DEhU" />
                            <div class="absolute top-2 right-2">
                                <span class="bg-secondary-container/90 backdrop-blur-sm text-on-secondary-container px-2 py-0.5 rounded-md text-[9px] font-extrabold uppercase">AVAILABLE</span>
                            </div>
                        </div>
                        <div class="px-1">
                            <h3 class="font-headline font-bold text-sm text-on-surface mb-2 line-clamp-1">맨큐의 경제학 (최신판)</h3>
                            <div class="flex justify-between items-end">
                                <div>
                                    <span class="text-primary font-bold text-base">3,500원</span>
                                    <span class="text-outline text-[10px]">/주</span>
                                </div>
                                <div class="flex flex-col items-end">
                                    <span class="text-[9px] font-bold text-primary mb-0.5">매너 42.0°C</span>
                                    <div class="w-14 h-1 bg-slate-100 rounded-full overflow-hidden">
                                        <div class="h-full bg-primary w-[85%]"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <!-- Floating Action Button -->
        <button class="fixed bottom-24 right-4 z-50 bg-primary text-white w-14 h-14 rounded-full shadow-lg flex items-center justify-center active:scale-90 transition-transform">
            <span class="material-symbols-outlined text-2xl font-bold">add</span>
        </button>

        <!-- Bottom Navigation Bar (Optimized for Mobile) -->
        <nav class="absolute bottom-0 left-0 w-full bg-white/90 backdrop-blur-xl border-t border-slate-100/50 pt-2 pb-6 px-6 flex justify-between items-center z-50 rounded-t-3xl shadow-[0_-10px_30px_rgba(0,0,0,0.05)]">
            <a class="flex flex-col items-center gap-1 group" href="#">
                <span class="material-symbols-outlined text-slate-400 group-hover:text-primary">home</span>
                <span class="text-[10px] font-bold text-slate-400 group-hover:text-primary uppercase">홈</span>
            </a>
            <a class="flex flex-col items-center gap-1 bg-blue-50 text-blue-700 px-5 py-2 rounded-2xl" href="#">
                <span class="material-symbols-outlined fill-1">map</span>
                <span class="text-[10px] font-bold uppercase">지도</span>
            </a>
            <a class="flex flex-col items-center gap-1 group" href="#">
                <span class="material-symbols-outlined text-slate-400 group-hover:text-primary">add_circle</span>
                <span class="text-[10px] font-bold text-slate-400 group-hover:text-primary uppercase">등록</span>
            </a>
            <a class="flex flex-col items-center gap-1 group" href="#">
                <span class="material-symbols-outlined text-slate-400 group-hover:text-primary">person</span>
                <span class="text-[10px] font-bold text-slate-400 group-hover:text-primary uppercase">프로필</span>
            </a>
        </nav>
    </div>
</body>
</html>
