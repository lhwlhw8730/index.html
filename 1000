<!DOCTYPE html>
<html class="light" lang="ko">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0040a1",
                        "secondary": "#705d00",
                        "surface": "#faf8ff",
                        "on-surface": "#191b23",
                        "outline": "#737785",
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Be Vietnam Pro"],
                    },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .fill-1 { font-variation-settings: 'FILL' 1; }
        body { -webkit-tap-highlight-color: transparent; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="font-body text-on-surface antialiased bg-slate-50">
    <div class="relative min-h-[100dvh] w-full max-w-md mx-auto bg-surface overflow-y-auto no-scrollbar shadow-2xl pb-32">
        
        <!-- Header -->
        <header class="sticky top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
            <div class="flex justify-between items-center px-5 py-4">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-blue-100 flex items-center justify-center overflow-hidden border border-primary/10">
                        <img alt="Profile" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCh922xeYmP9zG2laNLz_68sCNjVbVwwVtfc6OTeUfxya7c5l3cfSCUYIrYV905okG4xVs5kppqXPDX9c0M07i5gO4nYK_12csdksJFty4JOjQJriW2X3QeDhDkawWcQv_5bQgoI-XmI8bV0mQ4JZ2MLPd_o6PLAZ85vCPRnRHL1t_OyXByvTRpke_QfyLM27TPH_04yi8LxAAeXzexXv2jQkeSAOBxBWB291SinvNlaDL6jnkYxgsBkX7q9tr-769HXYWuC6Kaw-Y" />
                    </div>
                    <h1 class="text-lg font-extrabold text-primary font-headline tracking-tight">Academic Concierge</h1>
                </div>
                <button class="text-primary p-2 rounded-full active:scale-90 transition-transform">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
            </div>
        </header>

        <main class="px-5 py-6 space-y-6">
            <!-- Profile Card -->
            <section class="bg-white rounded-[2rem] p-6 shadow-sm border border-slate-100">
                <div class="space-y-1">
                    <span class="inline-block px-2.5 py-0.5 bg-primary text-white text-[9px] font-bold rounded-full uppercase">Verified Scholar</span>
                    <h2 class="text-2xl font-black text-on-surface">김지한 <span class="text-primary text-sm font-medium opacity-60">님</span></h2>
                    <p class="text-xs text-slate-500 font-medium">컴퓨터공학과 21학번</p>
                </div>
                <div class="mt-6 pt-6 border-t border-slate-50 space-y-4">
                    <div class="flex justify-between items-end">
                        <div class="space-y-1">
                            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Trust Grade</span>
                            <h3 class="text-xl font-black text-primary flex items-center gap-1.5">우수 <span class="text-secondary italic text-2xl">A+</span></h3>
                        </div>
                        <p class="text-xs font-bold text-primary">TOP 2%</p>
                    </div>
                    <div class="relative w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                        <div class="absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-secondary w-[92%] rounded-full"></div>
                    </div>
                </div>
            </section>

            <!-- Menu List -->
            <section class="bg-white rounded-[2rem] p-2 shadow-sm border border-slate-100">
                <nav class="flex flex-col">
                    <a class="flex justify-between items-center p-4 hover:bg-slate-50 rounded-2xl" href="#">
                        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-primary">person</span><span class="text-sm font-semibold">프로필 수정</span></div>
                        <span class="material-symbols-outlined text-slate-300">chevron_right</span>
                    </a>
                    <div class="h-px bg-slate-50 mx-4"></div>
                    <!-- Link to Map -->
                    <a class="flex justify-between items-center p-4 hover:bg-slate-50 rounded-2xl" href="10.html">
                        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-primary">map</span><span class="text-sm font-semibold">내 활동 반경 (지도)</span></div>
                        <span class="material-symbols-outlined text-slate-300">chevron_right</span>
                    </a>
                    <div class="h-px bg-slate-50 mx-4"></div>
                    <a class="flex justify-between items-center p-4 text-red-500" href="#">
                        <div class="flex items-center gap-3"><span class="material-symbols-outlined">logout</span><span class="text-sm font-semibold">로그아웃</span></div>
                    </a>
                </nav>
            </section>
        </main>

        <!-- Bottom Navigation -->
        <nav class="fixed bottom-0 left-0 right-0 w-full max-w-md mx-auto bg-white/90 backdrop-blur-xl border-t border-slate-100 pt-2 pb-6 px-6 flex justify-between items-center z-50 rounded-t-3xl shadow-lg">
            <a class="flex flex-col items-center gap-1 py-1 px-3" href="#">
                <span class="material-symbols-outlined text-slate-400">home</span>
                <span class="text-[10px] font-bold text-slate-400">홈</span>
            </a>
            <a class="flex flex-col items-center gap-1 py-1 px-3" href="10.html">
                <span class="material-symbols-outlined text-slate-400">map</span>
                <span class="text-[10px] font-bold text-slate-400">지도</span>
            </a>
            <a class="flex flex-col items-center gap-1 py-1 px-3" href="#">
                <span class="material-symbols-outlined text-slate-400">add_circle</span>
                <span class="text-[10px] font-bold text-slate-400">등록</span>
            </a>
            <a class="flex flex-col items-center gap-1 bg-blue-50 text-primary px-5 py-1.5 rounded-2xl shadow-sm" href="11.html">
                <span class="material-symbols-outlined fill-1">person</span>
                <span class="text-[10px] font-bold">프로필</span>
            </a>
        </nav>
    </div>
</body>
</html>
