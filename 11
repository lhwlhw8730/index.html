<!DOCTYPE html>
<html class="light" lang="ko">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface-container-lowest": "#ffffff",
                        "surface": "#faf8ff",
                        "surface-container-low": "#f2f3fe",
                        "surface-container": "#ededf8",
                        "error": "#ba1a1a",
                        "surface-dim": "#d9d9e4",
                        "surface-variant": "#e1e2ec",
                        "primary-fixed": "#dae2ff",
                        "primary": "#0040a1",
                        "inverse-surface": "#2e3038",
                        "on-surface": "#191b23",
                        "error-container": "#ffdad6",
                        "on-primary": "#ffffff",
                        "on-tertiary": "#ffffff",
                        "inverse-primary": "#b2c5ff",
                        "on-tertiary-fixed-variant": "#00531e",
                        "on-tertiary-container": "#54f67a",
                        "secondary": "#705d00",
                        "primary-container": "#0056d2",
                        "outline": "#737785",
                        "outline-variant": "#c3c6d6",
                        "tertiary-container": "#006e2a",
                        "tertiary-fixed": "#69ff87",
                        "on-primary-fixed-variant": "#0040a1",
                        "secondary-container": "#fdd400",
                        "on-surface-variant": "#424654",
                        "on-secondary-container": "#6f5c00",
                        "secondary-fixed-dim": "#e9c400",
                        "surface-container-highest": "#e1e2ec",
                        "surface-bright": "#faf8ff",
                        "tertiary": "#00531e",
                        "inverse-on-surface": "#f0f0fb",
                        "primary-fixed-dim": "#b2c5ff",
                        "on-secondary-fixed-variant": "#544600",
                        "on-error-container": "#93000a",
                        "on-error": "#ffffff",
                        "on-secondary-fixed": "#221b00",
                        "tertiary-fixed-dim": "#3ce36a",
                        "on-secondary": "#ffffff",
                        "surface-container-high": "#e7e7f2",
                        "background": "#faf8ff",
                        "on-background": "#191b23",
                        "surface-tint": "#0056d2",
                        "on-primary-fixed": "#001847",
                        "secondary-fixed": "#ffe170",
                        "on-primary-container": "#ccd8ff",
                        "on-tertiary-fixed": "#002108"
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Be Vietnam Pro"],
                        "label": ["Be Vietnam Pro"]
                    },
                    borderRadius: { "DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body {
            -webkit-tap-highlight-color: transparent;
            background-color: #f1f5f9;
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="font-body text-on-surface antialiased">
    <!-- 모바일 컨테이너 -->
    <div class="relative min-h-[100dvh] w-full max-w-md mx-auto bg-surface overflow-y-auto no-scrollbar shadow-2xl pb-32">
        
        <!-- Header -->
        <header class="sticky top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-surface-container-low">
            <div class="flex justify-between items-center px-5 py-4">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-primary-fixed flex items-center justify-center overflow-hidden border border-primary/10">
                        <img alt="Profile" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCh922xeYmP9zG2laNLz_68sCNjVbVwwVtfc6OTeUfxya7c5l3cfSCUYIrYV905okG4xVs5kppqXPDX9c0M07i5gO4nYK_12csdksJFty4JOjQJriW2X3QeDhDkawWcQv_5bQgoI-XmI8bV0mQ4JZ2MLPd_o6PLAZ85vCPRnRHL1t_OyXByvTRpke_QfyLM27TPH_04yi8LxAAeXzexXv2jQkeSAOBxBWB291SinvNlaDL6jnkYxgsBkX7q9tr-769HXYWuC6Kaw-Y" />
                    </div>
                    <h1 class="text-lg font-extrabold text-blue-700 font-headline tracking-tight">Profile</h1>
                </div>
                <button class="text-blue-700 p-2 rounded-full active:scale-90 transition-transform">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
            </div>
        </header>

        <main class="px-5 py-6 space-y-6">
            <!-- Profile Card -->
            <section class="bg-white rounded-[2rem] p-6 shadow-sm border border-surface-container relative overflow-hidden">
                <div class="absolute -top-12 -right-12 w-32 h-32 bg-primary/5 rounded-full blur-3xl"></div>
                <div class="space-y-1 relative">
                    <span class="inline-block px-2.5 py-0.5 bg-primary text-white text-[9px] font-bold rounded-full uppercase tracking-wider">Verified Scholar</span>
                    <h2 class="text-2xl font-black text-on-surface">김지한 <span class="text-primary text-sm font-medium opacity-60">님</span></h2>
                    <p class="text-xs text-on-surface-variant font-medium">컴퓨터공학과 21학번</p>
                </div>

                <!-- Trust Grade -->
                <div class="mt-6 pt-6 border-t border-surface-container-low space-y-4">
                    <div class="flex justify-between items-end">
                        <div class="space-y-1">
                            <span class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest">Trust Grade</span>
                            <h3 class="text-xl font-black text-primary flex items-center gap-1.5">우수 <span class="text-secondary font-black italic text-2xl">A+</span></h3>
                        </div>
                        <p class="text-xs font-bold text-primary">TOP 2%</p>
                    </div>
                    
                    <!-- Progress Bar -->
                    <div class="space-y-2">
                        <div class="relative w-full h-2 bg-surface-container rounded-full overflow-hidden">
                            <div class="absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-secondary w-[92%] rounded-full shadow-sm"></div>
                        </div>
                        <div class="flex justify-between text-[8px] font-bold text-on-surface-variant/40 uppercase">
                            <span>Bronze</span>
                            <span>Silver</span>
                            <span>Gold</span>
                            <span class="text-primary">Platinum</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Stats Grid -->
            <section class="grid grid-cols-2 gap-3">
                <div class="bg-primary-container/10 p-4 rounded-2xl flex flex-col justify-between border border-primary-container/10">
                    <span class="material-symbols-outlined text-primary text-2xl">inventory_2</span>
                    <div class="mt-4">
                        <p class="text-[10px] font-bold text-on-surface-variant opacity-70">빌려준 물품</p>
                        <h3 class="text-lg font-black text-on-surface">12건</h3>
                    </div>
                </div>
                <div class="bg-white p-4 rounded-2xl flex flex-col justify-between border border-surface-container shadow-sm">
                    <span class="material-symbols-outlined text-primary text-2xl">shopping_basket</span>
                    <div class="mt-4">
                        <p class="text-[10px] font-bold text-on-surface-variant opacity-70">대여한 물품</p>
                        <h3 class="text-lg font-black text-on-surface">8건</h3>
                    </div>
                </div>
                <div class="bg-secondary-container/10 p-4 rounded-2xl flex flex-col justify-between border border-secondary-container/20">
                    <span class="material-symbols-outlined text-secondary text-2xl">stars</span>
                    <div class="mt-4">
                        <p class="text-[10px] font-bold text-on-surface-variant opacity-70">리뷰</p>
                        <h3 class="text-lg font-black text-on-surface">24개</h3>
                    </div>
                </div>
                <div class="bg-white p-4 rounded-2xl flex flex-col justify-between border border-surface-container shadow-sm">
                    <span class="material-symbols-outlined text-primary text-2xl">account_balance_wallet</span>
                    <div class="mt-4">
                        <p class="text-[10px] font-bold text-on-surface-variant opacity-70">포인트</p>
                        <h3 class="text-lg font-black text-on-surface">45,000</h3>
                    </div>
                </div>
            </section>

            <!-- Recent Activity -->
            <section class="space-y-4">
                <div class="flex justify-between items-center px-1">
                    <h3 class="font-headline font-bold text-base">최근 활동 내역</h3>
                    <button class="text-primary text-[11px] font-bold">전체보기</button>
                </div>
                <div class="space-y-3">
                    <!-- Activity 1 -->
                    <div class="bg-white p-4 rounded-2xl flex items-center gap-4 shadow-sm border border-surface-container-low active:bg-slate-50 transition-colors">
                        <div class="w-16 h-16 rounded-xl overflow-hidden bg-slate-100 flex-shrink-0">
                            <img alt="item" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDBvoZFPcgu9zFn0_pxLW-b5Wk8UeO77lNw16PglShmiLyk3mqS6U1jRQ9_D9dWM2QD9pDpXmgl4jNdnJAjBi57h3s9pYUjMOqdWoUWWEeIxo-I5xY4sqh7bApch_TMSI6UwT21m-o9Qvtd7tVbQCUw95BNJvPvI-KSntMWT1knKxmEjIE12R_ix6E40C-QIPZLechS-zl0haOAv8zCaVqkplG-nNWPOWYaN0q4i_m29347TP9_KPzsYO7HUc1M1Bt5tDrTwKvLhiw" />
                        </div>
                        <div class="flex-grow">
                            <div class="flex justify-between items-center mb-1">
                                <span class="bg-secondary-container/30 text-on-secondary-container text-[8px] font-black px-2 py-0.5 rounded-full">LENT</span>
                                <span class="text-[9px] text-outline">오늘 18:00 반납예정</span>
                            </div>
                            <h4 class="text-sm font-bold text-on-surface line-clamp-1">기계식 키보드 (청축)</h4>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Menu List -->
            <section class="bg-white rounded-[2rem] p-2 shadow-sm border border-surface-container overflow-hidden">
                <nav class="flex flex-col">
                    <a class="flex justify-between items-center p-4 hover:bg-slate-50 active:bg-slate-100 rounded-2xl transition-colors" href="#">
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-primary">person</span>
                            <span class="text-sm font-semibold">프로필 수정</span>
                        </div>
                        <span class="material-symbols-outlined text-outline text-lg">chevron_right</span>
                    </a>
                    <a class="flex justify-between items-center p-4 hover:bg-slate-50 active:bg-slate-100 rounded-2xl transition-colors" href="#">
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-primary">verified_user</span>
                            <span class="text-sm font-semibold">학생증 인증 관리</span>
                        </div>
                        <span class="material-symbols-outlined text-outline text-lg">chevron_right</span>
                    </a>
                    <a class="flex justify-between items-center p-4 hover:bg-slate-50 active:bg-slate-100 rounded-2xl transition-colors" href="#">
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-primary">settings</span>
                            <span class="text-sm font-semibold">알림 및 환경설정</span>
                        </div>
                        <span class="material-symbols-outlined text-outline text-lg">chevron_right</span>
                    </a>
                    <div class="h-px bg-surface-container-low mx-4 my-1"></div>
                    <a class="flex justify-between items-center p-4 text-error active:bg-red-50 rounded-2xl transition-colors" href="#">
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined">logout</span>
                            <span class="text-sm font-semibold">로그아웃</span>
                        </div>
                    </a>
                </nav>
            </section>
        </main>

        <!-- Bottom Navigation (Shared with Map) -->
        <nav class="fixed bottom-0 left-0 right-0 w-full max-w-md mx-auto bg-white/90 backdrop-blur-xl border-t border-slate-100/50 pt-2 pb-6 px-6 flex justify-between items-center z-50 rounded-t-3xl shadow-[0_-10px_30px_rgba(0,0,0,0.05)]">
            <a class="flex flex-col items-center gap-1 group py-1 px-3" href="#">
                <span class="material-symbols-outlined text-slate-400">home</span>
                <span class="text-[9px] font-bold text-slate-400 uppercase">홈</span>
            </a>
            <a class="flex flex-col items-center gap-1 group py-1 px-3" href="#">
                <span class="material-symbols-outlined text-slate-400">map</span>
                <span class="text-[9px] font-bold text-slate-400 uppercase">지도</span>
            </a>
            <a class="flex flex-col items-center gap-1 group py-1 px-3" href="#">
                <span class="material-symbols-outlined text-slate-400">add_circle</span>
                <span class="text-[9px] font-bold text-slate-400 uppercase">등록</span>
            </a>
            <a class="flex flex-col items-center gap-1 bg-blue-50 text-blue-700 px-5 py-1.5 rounded-2xl shadow-sm" href="#">
                <span class="material-symbols-outlined fill-1">person</span>
                <span class="text-[9px] font-bold uppercase">프로필</span>
            </a>
        </nav>
    </div>
</body>
</html>
